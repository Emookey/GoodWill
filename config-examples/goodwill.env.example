# GoodWill staging laptop check config example
# Copy to ~/.config/goodwill/goodwill.env and replace placeholder values.
# Do not commit the real goodwill.env file.

# Use a Tailscale MagicDNS name, Tailscale IP, or private hostname.
GOODWILL_SSH="user@goodwill-server"

# GoodWill service URLs over Tailscale or private network.
GOODWILL_OPENWEBUI_URL="http://goodwill-server:3000"
GOODWILL_ODYSSEUS_URL="http://goodwill-server:7000"
GOODWILL_KUMA_URL="http://goodwill-server:3001"
GOODWILL_OLLAMA_URL="http://goodwill-server:11434/api/tags"

# Local public repo path on the staging laptop.
GOODWILL_REPO="$HOME/Projects/GoodWill"

# Set to 1 only if the server has a remote ~/bin/goodwill-check script.
GOODWILL_RUN_REMOTE_CHECK=0
