# Odysseus example environment file
#
# Copy only the needed values into your real .env file.
# Do not commit the real .env file.

# Ollama runs on the Ubuntu host while Odysseus runs in Docker.
# This path depends on docker-compose extra_hosts mapping.
OLLAMA_HOST=host.docker.internal
OLLAMA_BASE_URL=http://host.docker.internal:11434/v1
EMBEDDING_URL=http://host.docker.internal:11434/v1/embeddings

# Durable local lab app binding.
# Binding to 0.0.0.0 allows the host firewall/private-access layer to decide which interfaces can reach the service.
# Do not commit a real private IP-specific bind value to the public repository.
APP_BIND=0.0.0.0
APP_PORT=7000

# Example local app database path. Adjust according to your Odysseus deployment.
DATABASE_URL=sqlite:///./data/app.db

# Example local notification service path. Adjust if using ntfy.
NTFY_BASE_URL=http://localhost:8091

# Example embedding model choices.
EMBEDDING_MODEL=all-minilm:l6-v2
FASTEMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
